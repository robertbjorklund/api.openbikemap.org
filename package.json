{
  "name": "api.openbikemap.org",
  "version": "0.1.0",
  "description": "REST API for OpenBikeMap.org frontend",
  "main": "src/index.ts",
  "license": "Apache-2.0",
  "dependencies": {
    "express": "^5.2.1",
    "JSONStream": "^1.3.5",
    "pg": "^8.12.0",
    "stream-to-promise": "^3",
    "tslib": "^2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.16",
    "@types/pg": "^8.11.0",
    "@types/stream-to-promise": "^2.2.5",
    "@types/supertest": "^6.0.2",
    "@vitest/ui": "^4.0.0",
    "prettier": "^3.7.4",
    "supertest": "^7.2.2",
    "ts-node": "^10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "import-data": "node -r ts-node/register src/scripts/import_data.ts",
    "drop-database": "./scripts/drop-database.sh",
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "start": "node ./dist/index.js",
    "check-types": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
